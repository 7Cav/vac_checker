<?xml version="1.0" encoding="UTF-8"?>
<event_listeners>
    <!--
        Fires BEFORE save. We check isInsert() here while the entity is still
        "new", and stash a reference so entityPostSave knows this was an insert.
    -->
    <event_listener
        event_id="entity_pre_save"
        execute_order="10"
        callback_class="Cav7\SteamChecker\Listener"
        callback_method="entityPreSave"
        hint="XF:Thread"
        active="1"
        description="Steam VAC Checker: mark new thread inserts before save"
    />

    <!--
        Fires AFTER save. Triggers the VAC check only for threads that were
        marked as inserts by the entity_pre_save listener above.
    -->
    <event_listener
        event_id="entity_post_save"
        execute_order="10"
        callback_class="Cav7\SteamChecker\Listener"
        callback_method="entityPostSave"
        hint="XF:Thread"
        active="1"
        description="Steam VAC Checker: trigger check on new enlistment threads"
    />
</event_listeners>
